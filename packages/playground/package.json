{
  "name": "playground",
  "version": "1.0.0-dev",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "serve": "vite",
    "serve:ci": "vite build && vite preview",
    "build": "vite build --force",
    "build:static": "echo 'building for vercel' && yarn run build",
    "typecheck": "tsc --noEmit",
    "test": "playwright test --config=devEnv/playwright.config.ts",
    "test:ci": "playwright test --reporter=dot --config=devEnv/playwright.config.ts --project=chromium"
  },
  "devDependencies": {
    "@encorejs/core": "workspace:*",
    "@encorejs/dataverse": "workspace:*",
    "@encorejs/r3f": "workspace:*",
    "@encorejs/react": "workspace:*",
    "@encorejs/studio": "workspace:*",
    "@encorejs/tweak": "workspace:*",
    "@playwright/test": "^1.36.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/jest": "^26.0.23",
    "@types/lodash-es": "^4.17.4",
    "@types/node": "^15.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "dotenv": "^16.3.1",
    "fast-glob": "^3.3.0",
    "lodash-es": "^4.17.21",
    "maath": "^0.10.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "styled-components": "^6.1.13",
    "three": "0.184.0",
    "typescript": "5.1.6",
    "vite": "^4.3.9"
  }
