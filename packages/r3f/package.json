    "@types/three": "0.184.1",
    "esbuild": "^0.18.17",
    "lodash-es": "^4.17.21",
    "npm-run-all": "^4.1.5",
    "polished": "^4.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^4.2.0",
    "react-merge-refs": "^2.0.2",
    "react-shadow": "^20.4.0",
    "react-use-measure": "^2.1.1",
    "reakit": "^1.3.8",
    "styled-components": "^6.1.13",
    "three": "0.184.0",
    "three-stdlib": "^2.36.1",
    "tsx": "4.7.0",
    "typescript": "5.1.6",
    "zustand": "^3.5.1"
  },
  "peerDependencies": {
    "@encorejs/core": "*",
    "@encorejs/studio": "*",
    "@react-three/fiber": "^9.0.0",
    "react": ">=19",
    "react-dom": ">=19",
    "three": ">=0.156"
  }
