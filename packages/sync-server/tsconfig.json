{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "outDir": "dist",
    "types": ["node", "jest"],
    "baseUrl": ".",
    "composite": true,
    "paths": {
      "@encore/utils/*": ["../utils/src/*"],
      "@encore/app/*": ["../app/src/*"],
      "@encore/core/*": ["../core/src/*"],
      "@encore/core": ["../core/src/index.ts"]
    }
  },
  "references": [
    {"path": "../utils"},
    {"path": "../app"},
    {"path": "../saaz"},
    {"path": "../core"}
  ],
  "include": ["./env.d.ts", "./src/**/*", "devEnv/**/*", "./prisma/seed.ts"],
  "exclude": ["**/node_modules", "**/.*", "**/xeno", "**/dist", "**/.temp"]
}
